{
  "id": "pip",
  "name": "Pip",
  "description": "Python pip package manager aliases",
  "version": "1.0.0",
  "syncedAt": "2026-01-22",
  "attribution": {
    "source": "Oh My Zsh",
    "sourceUrl": "https://github.com/ohmyzsh/ohmyzsh/tree/master/plugins/pip",
