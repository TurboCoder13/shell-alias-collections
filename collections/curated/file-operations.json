  "aliases": [
    { "name": "grep", "value": "grep --color=auto", "description": "Grep with color" },
    { "name": "egrep", "value": "egrep --color=auto", "description": "Extended grep with color" },
    { "name": "fgrep", "value": "fgrep --color=auto", "description": "Fixed grep with color" },
    { "name": "h", "value": "history", "description": "Show command history" },
    { "name": "hg", "value": "history | grep", "description": "Search command history" },
