    { "name": "duf", "value": "du -sh *", "description": "Size of items in current dir" },
    { "name": "dfh", "value": "df -h", "description": "Disk free space" },
    { "name": "wcl", "value": "wc -l", "description": "Count lines" },
    { "name": "sortu", "value": "sort -u", "description": "Sort unique" },
    { "name": "cx", "value": "chmod +x", "description": "Make executable" },
    { "name": "000", "value": "chmod 000", "description": "Remove all permissions" },
    { "name": "644", "value": "chmod 644", "description": "Standard file permissions" },
    { "name": "755", "value": "chmod 755", "description": "Standard directory permissions" }
